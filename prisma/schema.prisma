generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          Int             @id @default(autoincrement())
  name        String
  description String          @default("")
  startDate   String          @default("")
  createdAt   DateTime        @default(now())
  members     ProjectMember[]
}

model Person {
  id        Int             @id @default(autoincrement())
  name      String
  role      String          @default("Medewerker")
  createdAt DateTime        @default(now())
  members   ProjectMember[]
}

model ProjectMember {
  id          Int         @id @default(autoincrement())
  projectId   Int
  personId    Int
  hourlyRate  Float       @default(100)
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  person      Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@unique([projectId, personId])
}

model TimeEntry {
  id              Int           @id @default(autoincrement())
  projectMemberId Int
  weekNumber      Int
  hours           Float
  type            String        @default("Realisatie") // "Planning" | "Realisatie"
  projectMember   ProjectMember @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)

  @@unique([projectMemberId, weekNumber, type])
}
